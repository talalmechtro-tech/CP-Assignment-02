#include <iostream>
#include <cmath>
using namespace std;

double stdev(double x[], int n) {

    double sum = 0;
    for (int i = 0; i < n; i++) {
        sum += x[i];
    }
    double mean = sum / n;

    double sumSquares = 0;
    for (int i = 0; i < n; i++) {
        double diff = x[i] - mean;
        sumSquares += diff * diff;
    }

    return sqrt(sumSquares / (n - 1));
}

int main() {

    double data[] = {2.0, 4.0, 4.0, 4.0, 5.0, 5.0, 7.0, 9.0};
    int n = 8;

    cout << "Standard deviation: " << stdev(data, n) << endl;

    return 0;
}
