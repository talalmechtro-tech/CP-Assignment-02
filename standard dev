#include <iostream>
#include <cmath>
using namespace std;

double calcMean(double x[], int n) {
    double sum = 0;
    for (int i = 0; i < n; i++) {
        sum = sum + x[i];
    }
    double mean = sum / n;
    return mean;
}

double stdev(double x[], int n) {
    double mean = calcMean(x, n);
    double sumOfSquares = 0;
    for (int i = 0; i < n; i++) {
        double diff = x[i] - mean;
        double squared = diff * diff;
        sumOfSquares = sumOfSquares + squared;
    }
    double result = sqrt(sumOfSquares / (n - 1));
    return result;
}

int main() {
    int n;
    cout << "How many numbers? ";
    cin >> n;
    double numbers[100];
    cout << "Enter " << n << " numbers: ";
    for (int i = 0; i < n; i++) {
        cin >> numbers[i];
    }
    double answer = stdev(numbers, n);
    cout << "Standard Deviation = " << answer << endl;
    return 0;
}
