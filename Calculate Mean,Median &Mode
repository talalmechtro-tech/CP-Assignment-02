#include<iostream>
using namespace std;

double calcMean(double a[], int n){
    double sum = 0;
    for(int i = 0; i < n; i++) sum += a[i];
    return sum / n;
}

double calcMedian(double a[], int n){
    double t[100];
    for(int i = 0; i < n; i++) t[i] = a[i];
    // bubble sort
    for(int i = 0; i < n-1; i++)
        for(int j = 0; j < n-i-1; j++)
            if(t[j] > t[j+1]){ double sw=t[j]; t[j]=t[j+1]; t[j+1]=sw; }
    return (n%2==0) ? (t[n/2-1]+t[n/2])/2.0 : t[n/2];
}

double calcMode(double a[], int n){
    double mode = a[0]; int high = 0;
    for(int i = 0; i < n; i++){
        int cnt = 0;
        for(int j = 0; j < n; j++) if(a[j]==a[i]) cnt++;
        if(cnt > high){ high = cnt; mode = a[i]; }
    }
    return mode;
}

int main(){
    int n;
    cout << "How many numbers? "; cin >> n;
    double arr[100];
    cout << "Enter numbers: ";
    for(int i = 0; i < n; i++) cin >> arr[i];
    cout << "Mean   = " << calcMean(arr,n)   << endl;
    cout << "Median = " << calcMedian(arr,n) << endl;
    cout << "Mode   = " << calcMode(arr,n)   << endl;
    return 0;
}
