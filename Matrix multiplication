#include <iostream>
using namespace std;

void getvalue(float m[3][3]) {
    cout << "Enter 9 values: " << endl;
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            cout << "[" << i << "][" << j << "] = ";
            cin >> m[i][j];
        }
    }
}

void computeAxA(float A[3][3], float B[3][3], float C[3][3]) {
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            C[i][j] = 0;
            for (int k = 0; k < 3; k++) {
                C[i][j] += A[i][k] * B[k][j];
            }
        }
    }
}

void printArray(float m[3][3]) {
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) cout << m[i][j] << "\t";
        cout << endl;
    }
}

int main() {
    float A[3][3], B[3][3], C[3][3];
    cout << "Matrix A:" << endl; getvalue(A);
    cout << "Matrix B:" << endl; getvalue(B);
    computeAxA(A, B, C);
    cout << "\nA:" << endl; printArray(A);
    cout << "\nB:" << endl; printArray(B);
    cout << "\nA x B:" << endl; printArray(C);
    return 0;
}
